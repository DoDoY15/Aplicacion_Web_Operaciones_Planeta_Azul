# Server
PORT=8080
ENV=development

# CORS — origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT - gerar com: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./scripts/private.pem
JWT_PUBLIC_KEY_PATH=./scripts/public.pem
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=168h

# Database (App)
DB_HOST=localhost
DB_PORT=5432
DB_USER=planeta_azul
DB_PASSWORD=your_password
DB_NAME=planeta_azul_app
DB_SSLMODE=disable

# Database (Fábrica - só leitura)
FABRICA_DB_HOST=localhost
FABRICA_DB_PORT=5432
FABRICA_DB_USER=readonly_user
FABRICA_DB_PASSWORD=your_password
FABRICA_DB_NAME=fabrica

# OCR Service (interno)
OCR_SERVICE_URL=http://localhost:9000
